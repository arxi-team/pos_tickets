<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Multi-Print Receipt Screen Template -->
    <t t-name="pos_multi_print.MultiPrintReceiptScreen" owl="1">
        <div class="receipt-screen screen">
            <div class="screen-content d-flex flex-column h-100 overflow-hidden">
                <div class="receipt-screen-container d-flex flex-column flex-grow-1 overflow-auto p-3">
                    <div class="pos-receipt-container">
                        <div class="pos-receipt p-2">
                            <div class="text-center">
                                <h2 style="margin: 10px 0;">Product Papers</h2>
                                <div style="border-top: 1px dashed #000; margin: 10px 0;"></div>
                            </div>

                            <!-- Display one line per product unit -->
                            <t t-foreach="props.printableProducts" t-as="product" t-key="product_index">
                                <div class="pos-receipt-product-unit" style="padding: 8px 0; border-bottom: 1px dashed #ccc;">
                                    <span style="font-size: 18px; font-weight: bold;" t-esc="product.product_name"/>
                                </div>
                            </t>

                            <div class="text-center" style="margin-top: 15px;">
                                <p style="font-size: 14px;">
                                    <t t-esc="props.printableProducts.length"/> pages will be printed
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Control buttons -->
                <div class="footer d-flex justify-content-between p-3 border-top">
                    <button class="btn btn-secondary" t-on-click="orderDone">
                        <i class="fa fa-check me-1"/> Next Order
                    </button>
                    <button class="btn btn-primary" t-on-click="doFullPrint">
                        <i class="fa fa-print me-1"/> Print
                    </button>
                </div>
            </div>
        </div>
    </t>

    <!-- Multi-Print Order Receipt Template -->
    <t t-name="pos_multi_print.MultiPrintOrderReceipt" owl="1">
        <div class="pos-receipt p-2">
            <div class="text-center">
                <h2 style="margin: 10px 0;">Product Papers</h2>
                <div style="border-top: 1px dashed #000; margin: 10px 0;"></div>
            </div>

            <!-- Display one line per product unit -->
            <t t-foreach="orderlines" t-as="product" t-key="product_index">
                <div class="pos-receipt-product-unit" style="padding: 8px 0; border-bottom: 1px dashed #ccc;">
                    <span style="font-size: 18px; font-weight: bold;" t-esc="product.product_name"/>
                </div>
            </t>

            <div class="text-center" style="margin-top: 15px;">
                <p style="font-size: 14px;">
                    <t t-esc="orderlines.length"/> pages will be printed
                </p>
            </div>
        </div>
    </t>
</templates>