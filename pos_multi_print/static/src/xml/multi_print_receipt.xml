<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Custom OrderReceipt template for multi-print mode -->
    <t t-name="point_of_sale.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <!-- Override the orderlines display when multi-print is enabled -->
        <xpath expr="//OrderWidget" position="attributes">
            <attribute name="t-if">!pos.multi_print_enabled and props.data.orderlines?.length</attribute>
        </xpath>

        <!-- Add multi-print product display -->
        <xpath expr="//OrderWidget" position="after">
            <div t-if="pos.multi_print_enabled" class="pos-receipt-multi-print">
                <div class="text-center">
                    <h2 style="margin: 10px 0;">Product Papers</h2>
                    <div style="border-top: 1px dashed #000; margin: 10px 0;"></div>
                </div>

                <!-- Display one line per product unit -->
                <t t-foreach="props.data.orderlines" t-as="product" t-key="product_index">
                    <div class="pos-receipt-product-unit" style="padding: 8px 0; border-bottom: 1px dashed #ccc;">
                        <span style="font-size: 18px; font-weight: bold;" t-esc="product.product_name"/>
                    </div>
                </t>

                <div class="text-center" style="margin-top: 15px;">
                    <p style="font-size: 14px;">
                        <t t-esc="props.data.orderlines.length"/> pages will be printed
                    </p>
                </div>
            </div>
        </xpath>
    </t>
</templates>