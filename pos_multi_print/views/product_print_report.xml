<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report definition for individual product printing -->
    <record id="report_pos_product_individual" model="ir.actions.report">
        <field name="name">Individual Product Print</field>
        <field name="model">pos.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_multi_print.product_individual_template</field>
        <field name="report_file">pos_multi_print.product_individual_template</field>
        <field name="print_report_name">'Products_{}.pdf'.format(object.name)</field>
        <field name="paperformat_id" ref="paper_format_product_individual"/>
        <field name="binding_model_id" ref="model_pos_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Simple Test Template -->
    <template id="product_individual_template">
        <t t-call="web.html_container">
            <div style="padding: 10mm;">
                <h1>DEBUG INFO</h1>
                <p>Docs count: <t t-esc="len(docs)"/></p>

                <t t-foreach="docs" t-as="doc">
                    <h2>Order: <t t-esc="doc.id"/></h2>
                    <p>Order name: <t t-esc="doc.name"/></p>
                    <p>Lines count: <t t-esc="len(doc.lines)"/></p>

                    <h3>Lines:</h3>
                    <ul>
                        <t t-foreach="doc.lines" t-as="line">
                            <li>
                                <t t-esc="line.product_id.name"/> x <t t-esc="line.qty"/>
                            </li>
                        </t>
                    </ul>

                    <h3>Multi-print products:</h3>
                    <p>Count: <t t-esc="len(doc.get_multi_print_products())"/></p>
                    <ul>
                        <t t-foreach="doc.get_multi_print_products()" t-as="product">
                            <li t-esc="product['name']"/>
                        </t>
                    </ul>
                </t>
            </div>
        </t>
    </template>
</odoo>
